---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';

const breadcrumbData = {
  items: [
    { name: 'Home', url: '/' },
    { name: 'Contact Us', url: '/contact/' }
  ]
};
---

<PageLayout 
  title="Contact HashBooks | Bookkeeping Services Support & Inquiries" 
  description="Have questions about your bookkeeping? Contact HashBooks at contact@hashbooks.site or submit our contact form."
  canonicalUrl="/contact/"
>
  <SchemaMarkup type="breadcrumb" data={breadcrumbData} slot="head" />
  <section class="section contact-hero">
    <div class="container text-center">
      <SectionHeading 
        eyebrow="Get In Touch"
        title="Let's Talk About Your Books"
        subtitle="Have a question? We respond within 2 business hours."
        as="h1"
      />
    </div>
  </section>

  <!-- Contact Form & Info Grid -->
  <section class="section section-alt">
    <div class="container contact-grid">
      <!-- Left: Contact Form -->
      <div class="card contact-form-card">
        <!-- Success message alert -->
        <div id="contact-success-alert" class="alert alert-success" style="display: none; margin-bottom: var(--space-4); padding: var(--space-4); background-color: rgba(16, 185, 129, 0.1); border: 1px solid var(--color-semantic-success); border-radius: var(--radius-md); color: var(--color-secondary);">
          <div style="display: flex; gap: var(--space-3); align-items: center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <div>
              <strong style="font-weight: 700;">Message Sent Successfully!</strong>
              <p style="font-size: var(--fs-caption); margin: 0; color: var(--color-text-body);">Thank you for contacting Hashbooks. We will respond to your inquiry within 2 business hours.</p>
            </div>
          </div>
        </div>

        <!-- Error message alert -->
        <div id="contact-error-alert" class="alert alert-error" style="display: none; margin-bottom: var(--space-4); padding: var(--space-4); background-color: rgba(239, 68, 68, 0.1); border: 1px solid var(--color-semantic-error); border-radius: var(--radius-md); color: var(--color-semantic-error);">
          <div style="display: flex; gap: var(--space-3); align-items: center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <div>
              <strong style="font-weight: 700;">Failed to Send Message</strong>
              <p id="contact-error-text" style="font-size: var(--fs-caption); margin: 0; color: var(--color-text-body);">Something went wrong. Please try again or email us directly at contact@hashbooks.site.</p>
            </div>
          </div>
        </div>

        <form id="contact-form"
              class="contact-form"
              toolname="sendContactInquiry"
              tooldescription="Submit general inquiries, support requests, or consultation questions to the Hashbooks team.">
          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-name" class="form-label">Full Name</label>
              <input type="text" id="contact-name" name="name" class="form-input" placeholder="Muhammad Faisal" toolparamdescription="Full name of the person sending the inquiry" required maxlength="100" />
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">Email Address</label>
              <input type="email" id="contact-email" name="email" class="form-input" placeholder="faisal@company.com" toolparamdescription="Email address of the sender" required maxlength="254" />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-phone" class="form-label">Phone Number (Optional)</label>
              <input type="tel" id="contact-phone" name="phone" class="form-input" placeholder="(555) 000-0000" toolparamdescription="Phone number of the sender (optional)" maxlength="25" pattern="[0-9+\-\(\)\s]{7,25}" title="Please enter a valid phone number (digits, spaces, or +-() symbols only)" />
            </div>
            <div class="form-group">
              <label for="contact-company" class="form-label">Company Name</label>
              <input type="text" id="contact-company" name="company" class="form-input" placeholder="Bloom Commerce" toolparamdescription="Company name of the sender" required maxlength="150" />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">How can we help you?</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="5" placeholder="I need catch-up bookkeeping for the past 6 months..." toolparamdescription="Detailed description of the question, support issue, or consultation request" required maxlength="3000"></textarea>
          </div>

          <Button text="Send Message" type="submit" variant="primary" class="submit-btn" id="contact-submit-btn" />
        </form>

        <script is:inline>
          const form = document.getElementById('contact-form');
          const submitBtn = document.getElementById('contact-submit-btn');
          const successAlert = document.getElementById('contact-success-alert');
          const errorAlert = document.getElementById('contact-error-alert');
          const errorText = document.getElementById('contact-error-text');

          if (form) {
            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              
              // Clear previous alerts
              successAlert.style.display = 'none';
              errorAlert.style.display = 'none';
              
              // Set loading state
              submitBtn.disabled = true;
              const originalBtnText = submitBtn.textContent || 'Send Message';
              submitBtn.textContent = 'Sending...';

              const formData = new FormData(form);
              const data = {
                name: formData.get('name'),
                email: formData.get('email'),
                phone: formData.get('phone'),
                company: formData.get('company'),
                message: formData.get('message'),
                subject: 'New Contact Inquiry - Hashbooks'
              };

              try {
                const response = await fetch('/api/send-email', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok && result.success) {
                  successAlert.style.display = 'block';
                  form.reset();
                  // Scroll to top of form
                  successAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                } else {
                  errorText.textContent = result.error || 'Failed to send your message. Please try again later.';
                  errorAlert.style.display = 'block';
                  errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
              } catch (err) {
                console.error(err);
                errorText.textContent = 'A network error occurred. Please check your connection and try again.';
                errorAlert.style.display = 'block';
                errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalBtnText;
              }
            });
          }
        </script>
      </div>

      <!-- Right: Direct Contact Info -->
      <div class="contact-info-column">
        <!-- Card 1: Calendly Booking -->
        <div class="card info-mini-card highlight-card">
          <div class="info-icon-box highlight-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Book a Free Call</h3>
            <a href="https://calendly.com/hashbooksofficial" class="info-card-value highlight-value" target="_blank" rel="noopener noreferrer">Schedule on Calendly &rarr;</a>
            <p class="info-card-desc">Choose a time slot for a free 15-minute bookkeeping consultation.</p>
          </div>
        </div>

        <!-- Card 2: Email -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Email Us Directly</h3>
            <a href="mailto:contact@hashbooks.site" class="info-card-value">contact@hashbooks.site</a>
            <p class="info-card-desc">For general questions or support inquiries.</p>
          </div>
        </div>

        <!-- Card 2: Hours -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Office Hours</h3>
            <p class="info-card-value-text">Monday - Saturday</p>
            <p class="info-card-value-text">9:00 AM - 5:00 PM EST</p>
            <p class="info-card-desc">Reconciliations performed daily.</p>
          </div>
        </div>

        <!-- Card 3: WhatsApp -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-message-circle"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">WhatsApp</h3>
            <a href="https://wa.me/923180690265" class="info-card-value" target="_blank" rel="noopener noreferrer">+92 318 0690265</a>
            <p class="info-card-desc">Chat with us anytime.</p>
          </div>
        </div>

        <!-- Card 4: Location -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Location</h3>
            <p class="info-card-value-text">PCSIR Phase 2, Johar Town, Lahore</p>
            <p class="info-card-desc">Office location.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: radial-gradient(circle at 10% 20%, rgba(26, 122, 61, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(7, 32, 73, 0.02) 0%, transparent 40%);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-4);
  }

  @media (min-width: 992px) {
    .contact-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 576px) {
    .form-row-2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .submit-btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .contact-info-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 991px) {
    .contact-info-column {
      order: -1;
    }
  }

  .info-mini-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-color: var(--color-border);
  }

  @media (min-width: 480px) {
    .info-mini-card {
      flex-direction: row;
      gap: var(--space-4);
    }
  }

  .info-icon-box {
    color: var(--color-secondary);
    background-color: rgba(26, 122, 61, 0.05);
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-card-title {
    font-size: var(--fs-body-sm);
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: var(--color-text-heading);
  }

  .info-card-value {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-secondary);
    display: block;
    margin-bottom: 4px;
  }
  .info-card-value:hover {
    text-decoration: underline;
  }

  .info-card-value-text {
    font-size: var(--fs-body-sm);
    font-weight: 600;
    color: var(--color-text-body);
  }

  .info-card-desc {
    font-size: var(--fs-caption);
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  .highlight-card {
    border-color: var(--color-secondary-light) !important;
    background: linear-gradient(135deg, rgba(26, 122, 61, 0.02) 0%, transparent 100%) !important;
    box-shadow: 0 4px 20px -2px rgba(26, 122, 61, 0.08) !important;
  }
  .highlight-icon-box {
    color: var(--color-white) !important;
    background-color: var(--color-secondary) !important;
  }
  .highlight-value {
    color: var(--color-secondary-light) !important;
  }
</style>
