---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout 
  title="Contact Hashbooks | Bookkeeping Services Support & Inquiries" 
  description="Have questions about your bookkeeping? Contact the Hashbooks team at contact@hashbooks.site or submit our contact form."
  canonicalUrl="/contact/"
>
  <section class="section contact-hero">
    <div class="container text-center">
      <SectionHeading 
        eyebrow="Get In Touch"
        title="Let's Talk About Your Books"
        subtitle="Have a question? We respond within 2 business hours."
        as="h1"
      />
    </div>
  </section>

  <!-- Contact Form & Info Grid -->
  <section class="section section-alt">
    <div class="container contact-grid">
      <!-- Left: Contact Form -->
      <div class="card contact-form-card">
        <form action="https://formspree.io/f/placeholder" method="POST" class="contact-form">
          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-name" class="form-label">Full Name</label>
              <input type="text" id="contact-name" name="name" class="form-input" placeholder="Muhammad Faisal" required />
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">Email Address</label>
              <input type="email" id="contact-email" name="email" class="form-input" placeholder="faisal@company.com" required />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-phone" class="form-label">Phone Number (Optional)</label>
              <input type="tel" id="contact-phone" name="phone" class="form-input" placeholder="(555) 000-0000" />
            </div>
            <div class="form-group">
              <label for="contact-company" class="form-label">Company Name</label>
              <input type="text" id="contact-company" name="company" class="form-input" placeholder="Bloom Commerce" required />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">How can we help you?</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="5" placeholder="I need catch-up bookkeeping for the past 6 months..." required></textarea>
          </div>

          <Button text="Send Message" type="submit" variant="primary" class="submit-btn" />
        </form>
      </div>

      <!-- Right: Direct Contact Info -->
      <div class="contact-info-column">
        <!-- Card 1: Email -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Email Us Directly</h3>
            <a href="mailto:contact@hashbooks.site" class="info-card-value">contact@hashbooks.site</a>
            <p class="info-card-desc">For general questions or support inquiries.</p>
          </div>
        </div>

        <!-- Card 2: Hours -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Office Hours</h3>
            <p class="info-card-value-text">Monday - Friday</p>
            <p class="info-card-value-text">9:00 AM - 5:00 PM EST</p>
            <p class="info-card-desc">Reconciliations performed daily.</p>
          </div>
        </div>

        <!-- Card 3: Phone -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Call Us</h3>
            <a href="tel:+923180690265" class="info-card-value">+92 318 0690265</a>
            <p class="info-card-desc">Direct support line.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-hero {
    padding-bottom: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-4);
  }

  @media (min-width: 992px) {
    .contact-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 576px) {
    .form-row-2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .submit-btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .contact-info-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-mini-card {
    display: flex;
    gap: var(--space-4);
    border-color: var(--color-border);
  }

  .info-icon-box {
    color: var(--color-secondary);
    background-color: rgba(26, 122, 61, 0.05);
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-card-title {
    font-size: var(--fs-body-sm);
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: var(--color-text-heading);
  }

  .info-card-value {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-secondary);
    display: block;
    margin-bottom: 4px;
  }
  .info-card-value:hover {
    text-decoration: underline;
  }

  .info-card-value-text {
    font-size: var(--fs-body-sm);
    font-weight: 600;
    color: var(--color-text-body);
  }

  .info-card-desc {
    font-size: var(--fs-caption);
    color: var(--color-text-muted);
    margin-top: 4px;
  }
</style>
