---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout 
  title="Contact Hashbooks | Bookkeeping Services Support & Inquiries" 
  description="Have questions about your bookkeeping? Contact the Hashbooks team at contact@hashbooks.site or submit our contact form."
  canonicalUrl="/contact/"
>
  <section class="section contact-hero">
    <div class="container text-center">
      <SectionHeading 
        eyebrow="Get In Touch"
        title="Let's Talk About Your Books"
        subtitle="Have a question? We respond within 2 business hours."
        as="h1"
      />
    </div>
  </section>

  <!-- Contact Form & Info Grid -->
  <section class="section section-alt">
    <div class="container contact-grid">
      <!-- Left: Contact Form -->
      <div class="card contact-form-card">
        <!-- Success message alert -->
        <div id="contact-success-alert" class="alert alert-success" style="display: none; margin-bottom: var(--space-4); padding: var(--space-4); background-color: rgba(16, 185, 129, 0.1); border: 1px solid var(--color-semantic-success); border-radius: var(--radius-md); color: var(--color-secondary);">
          <div style="display: flex; gap: var(--space-3); align-items: center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <div>
              <strong style="font-weight: 700;">Message Sent Successfully!</strong>
              <p style="font-size: var(--fs-caption); margin: 0; color: var(--color-text-body);">Thank you for contacting Hashbooks. We will respond to your inquiry within 2 business hours.</p>
            </div>
          </div>
        </div>

        <form action="https://formsubmit.co/hashbooksofficial@gmail.com" method="POST" class="contact-form">
          <!-- FormSubmit Configuration -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_next" value="https://hashbooks.site/contact/?success=true" />
          <input type="hidden" name="_subject" value="New Contact Inquiry - Hashbooks" />

          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-name" class="form-label">Full Name</label>
              <input type="text" id="contact-name" name="name" class="form-input" placeholder="Muhammad Faisal" required maxlength="100" />
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">Email Address</label>
              <input type="email" id="contact-email" name="email" class="form-input" placeholder="faisal@company.com" required maxlength="254" />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label for="contact-phone" class="form-label">Phone Number (Optional)</label>
              <input type="tel" id="contact-phone" name="phone" class="form-input" placeholder="(555) 000-0000" maxlength="25" pattern="[0-9+\-\(\)\s]{7,25}" title="Please enter a valid phone number (digits, spaces, or +-() symbols only)" />
            </div>
            <div class="form-group">
              <label for="contact-company" class="form-label">Company Name</label>
              <input type="text" id="contact-company" name="company" class="form-input" placeholder="Bloom Commerce" required maxlength="150" />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">How can we help you?</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="5" placeholder="I need catch-up bookkeeping for the past 6 months..." required maxlength="3000"></textarea>
          </div>

          <Button text="Send Message" type="submit" variant="primary" class="submit-btn" />
        </form>

        <script is:inline>
          if (window.location.search.includes('success=true')) {
            const alertEl = document.getElementById('contact-success-alert');
            if (alertEl) {
              alertEl.style.display = 'block';
              // Clean up the URL query parameters
              const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
              window.history.replaceState({ path: newUrl }, '', newUrl);
            }
          }
        </script>
      </div>

      <!-- Right: Direct Contact Info -->
      <div class="contact-info-column">
        <!-- Card 1: Email -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Email Us Directly</h3>
            <a href="mailto:contact@hashbooks.site" class="info-card-value">contact@hashbooks.site</a>
            <p class="info-card-desc">For general questions or support inquiries.</p>
          </div>
        </div>

        <!-- Card 2: Hours -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Office Hours</h3>
            <p class="info-card-value-text">Monday - Friday</p>
            <p class="info-card-value-text">9:00 AM - 5:00 PM EST</p>
            <p class="info-card-desc">Reconciliations performed daily.</p>
          </div>
        </div>

        <!-- Card 3: Phone -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Call Us</h3>
            <a href="tel:+923180690265" class="info-card-value">+92 318 0690265</a>
            <p class="info-card-desc">Direct support line.</p>
          </div>
        </div>

        <!-- Card 4: Location -->
        <div class="card info-mini-card">
          <div class="info-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div class="info-content">
            <h3 class="info-card-title">Location</h3>
            <p class="info-card-value-text">PCSIR Phase 2, Johar Town, Lahore</p>
            <p class="info-card-desc">Office location.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: radial-gradient(circle at 10% 20%, rgba(26, 122, 61, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(7, 32, 73, 0.02) 0%, transparent 40%);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-4);
  }

  @media (min-width: 992px) {
    .contact-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 576px) {
    .form-row-2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .submit-btn {
    width: 100%;
    margin-top: var(--space-2);
  }

  .contact-info-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 991px) {
    .contact-info-column {
      order: -1;
    }
  }

  .info-mini-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-color: var(--color-border);
  }

  @media (min-width: 480px) {
    .info-mini-card {
      flex-direction: row;
      gap: var(--space-4);
    }
  }

  .info-icon-box {
    color: var(--color-secondary);
    background-color: rgba(26, 122, 61, 0.05);
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-card-title {
    font-size: var(--fs-body-sm);
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: var(--color-text-heading);
  }

  .info-card-value {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-secondary);
    display: block;
    margin-bottom: 4px;
  }
  .info-card-value:hover {
    text-decoration: underline;
  }

  .info-card-value-text {
    font-size: var(--fs-body-sm);
    font-weight: 600;
    color: var(--color-text-body);
  }

  .info-card-desc {
    font-size: var(--fs-caption);
    color: var(--color-text-muted);
    margin-top: 4px;
  }
</style>
