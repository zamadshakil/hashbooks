---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import PlatformsShowcase from '../components/sections/PlatformsShowcase.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTASection from '../components/sections/CTASection.astro';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';
---

<PageLayout 
  title="Bookkeeping Services & QuickBooks Online | Hashbooks" 
  description="Certified monthly bookkeeping services, QuickBooks set-up and clean up, bank reconciliation, AR/AP management, and financial reporting for US small businesses."
  canonicalUrl="/"
>
  <SchemaMarkup type="organization" slot="head" />
  <Hero />
  <TrustBar />
  <ProblemSection />
  <ServicesGrid />
  <HowItWorks />
  <WhyChooseUs />
  <StatsSection />
  <PlatformsShowcase />
  <Testimonials />
  <CTASection />
</PageLayout>
