---
interface Props {
  type: 'organization' | 'service' | 'faq' | 'breadcrumb' | 'article' | 'techArticle';
  data?: any;
}

const { type, data } = Astro.props;
const siteUrl = 'https://hashbooks.site';

function getSchema() {
  switch (type) {
    case 'organization':
      return {
        "@context": "https://schema.org",
        "@type": "AccountingService",
        "name": "Hashbooks",
        "url": siteUrl,
        "logo": `${siteUrl}/images/logo.png`,
        "description": "Professional bookkeeping services for growing businesses. Expert monthly bookkeeping, tax preparation, payroll, financial reporting, and Virtual Fractional CFO services.",
        "email": "contact@hashbooks.site",
        "telephone": "+923180690265",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+923180690265",
          "contactType": "customer service",
          "email": "contact@hashbooks.site",
          "availableLanguage": "English"
        },
        "areaServed": ["US", "UK", "UAE", "Worldwide"],
        "serviceType": "Bookkeeping Services",
        "priceRange": "$$",
        "sameAs": []
      };

    case 'service':
      return {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": data?.title,
        "description": data?.description,
        "provider": {
          "@type": "AccountingService",
          "name": "Hashbooks",
          "url": siteUrl
        },
        "url": `${siteUrl}${data?.url}`
      };

    case 'faq':
      return {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": data?.items?.map((item: any) => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer
          }
        }))
      };

    case 'breadcrumb':
      return {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": data?.items?.map((item: any, index: number) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": item.name,
          "item": item.url ? `${siteUrl}${item.url}` : undefined
        }))
      };

    case 'article':
      return {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": data?.title,
        "description": data?.description,
        "image": data?.image ? (data.image.startsWith('http') ? data.image : `${siteUrl}${data.image}`) : undefined,
        "datePublished": data?.datePublished,
        "dateModified": data?.dateModified || data?.datePublished,
        "author": {
          "@type": "Person",
          "name": data?.author || "M Hassan Shakeel"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Hashbooks",
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/images/logo.png`
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": `${siteUrl}${data?.url}`
        }
      };

    case 'techArticle':
      return {
        "@context": "https://schema.org",
        "@type": "TechArticle",
        "headline": data?.title,
        "description": data?.description,
        "image": data?.image ? (data.image.startsWith('http') ? data.image : `${siteUrl}${data.image}`) : undefined,
        "dependencies": data?.skills?.join(', '),
        "publisher": {
          "@type": "Organization",
          "name": "Hashbooks",
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/images/logo.png`
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": `${siteUrl}${data?.url}`
        }
      };

    default:
      return null;
  }
}

const schema = getSchema();
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
