---
import navData from '../../data/navigation.json';

const mainNav = navData.main;
const ctaNav = navData.cta;
---

<div id="mobile-menu" class="mobile-menu-drawer" aria-hidden="true">
  <div class="mobile-menu-inner">
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <ul class="mobile-nav-list">
        {mainNav.map((item) => (
          <li class="mobile-nav-item">
            {item.children ? (
              <details class="mobile-nav-details">
                <summary class="mobile-nav-summary">
                  {item.label}
                  <svg class="summary-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </summary>
                <ul class="mobile-sub-list">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href} class="mobile-sub-link">
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={item.href} class="mobile-nav-link">
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
    
    <div class="mobile-menu-actions">
      <a href={ctaNav.href} class="btn btn-primary btn-lg w-full">{ctaNav.label}</a>
      <div class="mobile-social-links">
        <a href="https://web.facebook.com/profile.php?id=61591687396646" target="_blank" rel="noopener noreferrer" class="mobile-social-link" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="https://www.instagram.com/hashbooksofficial/" target="_blank" rel="noopener noreferrer" class="mobile-social-link" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://www.linkedin.com/company/135165670" target="_blank" rel="noopener noreferrer" class="mobile-social-link" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .mobile-menu-drawer {
    position: fixed;
    top: 70px;
    left: 0;
    width: 100%;
    height: calc(100vh - 70px);
    height: calc(100dvh - 70px);
    background-color: var(--color-white);
    z-index: 99;
    transform: translateX(100%);
    transition: transform var(--transition-normal), visibility var(--transition-normal);
    overflow-y: auto;
    visibility: hidden;
  }

  .mobile-menu-drawer.is-open {
    transform: translateX(0);
    visibility: visible;
  }

  .mobile-menu-inner {
    padding: var(--space-6) var(--space-4) var(--space-12) var(--space-4);
    display: flex;
    flex-direction: column;
    min-height: 100%;
    justify-content: space-between;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-nav-link, .mobile-nav-summary {
    font-size: var(--fs-body-lg);
    font-weight: 600;
    color: var(--color-text-heading);
    padding: var(--space-3) 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-nav-summary {
    list-style: none;
    cursor: pointer;
  }
  .mobile-nav-summary::-webkit-details-marker {
    display: none;
  }

  .summary-chevron {
    transition: transform var(--transition-fast);
  }
  .mobile-nav-details[open] .summary-chevron {
    transform: rotate(180deg);
  }

  .mobile-sub-list {
    padding-left: var(--space-4);
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-left: 2px solid var(--color-border);
  }

  .mobile-sub-link {
    font-size: var(--fs-body-sm);
    color: var(--color-text-body);
    padding: var(--space-3) 0;
    display: block;
  }

  .mobile-menu-actions {
    margin-top: var(--space-8);
  }

  .mobile-social-links {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .mobile-social-link {
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .mobile-social-link:hover {
    color: var(--color-secondary);
    border-color: var(--color-secondary-light);
    background-color: rgba(26, 122, 61, 0.05);
    transform: translateY(-1px);
  }

  .w-full {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .mobile-menu-drawer {
      display: none;
    }
  }
</style>
