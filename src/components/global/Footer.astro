---
import { Image } from 'astro:assets';
import navData from '../../data/navigation.json';
import logoImg from '../../assets/logo.png';

const footerNav = navData.footer;
const currentYear = new Date().getFullYear();
---

<footer id="site-footer" class="section section-dark">
  <div class="container footer-grid">
    <!-- Brand Info -->
    <div class="footer-col brand-col">
      <a href="/" class="footer-logo">
        <Image src={logoImg} alt="Hashbooks Logo" class="footer-logo-img" width={32} height={32} loading="lazy" />
        Hash<span>Books</span>
      </a>
      <p class="footer-tagline">Accurate Books. Better Business.</p>
      <p class="footer-desc">
        Hashbooks provides certified bookkeeping and Virtual Fractional CFO services to help growing businesses scale with financial clarity and peace of mind.
      </p>
      <div class="partner-badges">
        <span class="badge badge-success">QuickBooks ProAdvisor</span>
        <span class="badge badge-primary">Xero Certified</span>
        <a href="https://www.upwork.com/freelancers/~01bb0db4f7ec9f3be3?mp_source=share" target="_blank" rel="noopener noreferrer" class="badge badge-upwork">Upwork Profile</a>
        <a href="https://www.fiverr.com/s/5r6GElE" target="_blank" rel="noopener noreferrer" class="badge badge-fiverr">Fiverr Gig</a>
      </div>
      <div class="social-links">
        <a href="https://web.facebook.com/profile.php?id=61591687396646" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Facebook" title="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="https://www.instagram.com/hashbooksofficial/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram" title="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://www.linkedin.com/company/135165670" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
        <a href="https://www.upwork.com/freelancers/~01bb0db4f7ec9f3be3?mp_source=share" target="_blank" rel="noopener noreferrer" class="social-link social-link-upwork" aria-label="Upwork" title="Upwork">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.396-2.012 1.344-3.559 2.838-3.559 1.157 0 1.954.896 1.954 2.227 0 2.115-1.026 3.677-1.954 3.677zm.156-8.158c-3.138 0-5.068 2.308-5.717 4.966-1.127-1.782-1.989-4.223-2.585-6.966h-2.92v9.33c0 1.637-.678 2.651-2.028 2.651-1.352 0-2.031-1.014-2.031-2.651v-9.33h-2.918v9.33c0 3.328 1.921 5.372 4.949 5.372 3.024 0 4.947-2.044 4.947-5.372v-1.614c.604 1.912 1.579 3.675 2.859 4.981l-1.464 5.922h2.951l.995-4.024c.949.467 1.996.727 3.102.727 3.313 0 5.163-2.673 5.163-6.677 0-3.92-2.083-6.641-4.728-6.641z"/></svg>
        </a>
        <a href="https://www.fiverr.com/s/5r6GElE" target="_blank" rel="noopener noreferrer" class="social-link social-link-fiverr" aria-label="Fiverr" title="Fiverr">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 15.011h-2.073v-5.232H23v5.232zm-3.344-5.232h-1.696v1.173h-1.036v-1.173h-1.488v5.232h1.488v-2.316h1.036v2.316h1.696v-5.232zm-5.464 0h-1.688v1.173h-1.044v-1.173h-1.488v5.232h1.488v-2.316h1.044v2.316h1.688v-5.232zm-6.177 0H6.326v-1.164H4.838v1.164H3.801v1.173h1.037v4.059h1.488v-4.059h1.689v-1.173zM2.801 9.779H1.105v5.232h1.696v-5.232z"/></svg>
        </a>
      </div>
    </div>

    <!-- Links Columns -->
    <div class="footer-col">
      <h3 class="footer-title">Services</h3>
      <ul class="footer-links">
        {footerNav.services.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-title">Company</h3>
      <ul class="footer-links">
        {footerNav.company.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-title">More Services</h3>
      <ul class="footer-links">
        {footerNav.resources.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-col contact-col">
      <h3 class="footer-title">Connect</h3>
      <ul class="footer-contact-list">
        <li>
          <span class="contact-label">Email:</span>
          <a href="mailto:contact@hashbooks.site" class="contact-val">contact@hashbooks.site</a>
        </li>
        <li>
          <span class="contact-label">WhatsApp:</span>
          <a href="https://wa.me/923180690265" class="contact-val" target="_blank" rel="noopener noreferrer">+92 318 0690265</a>
        </li>
        <li>
          <span class="contact-label">Hours:</span>
          <span class="contact-val">Mon - Sat, 9am - 5pm EST</span>
        </li>
        <li>
          <span class="contact-label">Location:</span>
          <span class="contact-val">Serving Clients Globally (US, UK, UAE & Worldwide)</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Sub Footer -->
  <div class="container sub-footer">
    <div class="sub-footer-inner">
      <p class="copyright">&copy; {currentYear} Hashbooks. All rights reserved.</p>
      <ul class="legal-links">
        {footerNav.legal.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  #site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--color-primary-dark);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr 1.2fr;
    }
    .brand-col {
      grid-column: span 1;
    }
  }

  .footer-logo {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-white);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .footer-logo span {
    color: var(--color-secondary-light);
  }

  .footer-logo-img {
    height: 32px;
    width: 32px;
    max-width: 32px;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .footer-tagline {
    font-size: var(--fs-body-sm);
    font-weight: 600;
    color: var(--color-secondary-light);
    margin-bottom: var(--space-4);
  }

  .footer-desc {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-4);
  }

  .partner-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .partner-badges .badge {
    padding: 6px 12px;
    font-size: var(--fs-caption);
    font-weight: 600;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    display: inline-block;
  }

  .partner-badges .badge-success {
    background-color: rgba(52, 211, 153, 0.12);
    color: #34d399;
    border-color: rgba(52, 211, 153, 0.25);
  }

  .partner-badges .badge-primary {
    background-color: rgba(96, 165, 250, 0.12);
    color: #60a5fa;
    border-color: rgba(96, 165, 250, 0.25);
  }

  .partner-badges .badge-upwork {
    background-color: rgba(20, 168, 0, 0.15);
    color: #14a800;
    border-color: rgba(20, 168, 0, 0.3);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .partner-badges .badge-upwork:hover {
    background-color: rgba(20, 168, 0, 0.25);
    color: #1be000;
  }

  .partner-badges .badge-fiverr {
    background-color: rgba(29, 191, 115, 0.15);
    color: #1dbf73;
    border-color: rgba(29, 191, 115, 0.3);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .partner-badges .badge-fiverr:hover {
    background-color: rgba(29, 191, 115, 0.25);
    color: #24e58a;
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .social-link {
    color: rgba(255, 255, 255, 0.6);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-white);
    background-color: var(--color-secondary);
    border-color: var(--color-secondary-light);
    transform: translateY(-2px);
  }

  .footer-title {
    font-size: var(--fs-body-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-4);
    color: var(--color-white);
  }

  .footer-links li {
    margin-bottom: var(--space-1);
  }
  .footer-links a {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.7);
    display: inline-block;
    padding: 6px 0;
  }
  .footer-links a:hover {
    color: var(--color-white);
  }

  .footer-contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-contact-list li {
    font-size: var(--fs-body-sm);
  }
  .contact-label {
    display: block;
    font-weight: 600;
    color: var(--color-secondary-light);
  }
  .contact-val {
    color: rgba(255, 255, 255, 0.8);
    display: inline-block;
    padding: 6px 0;
  }
  .contact-val:hover {
    color: var(--color-white);
  }

  /* Sub-footer */
  .sub-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-6);
  }

  .sub-footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .sub-footer-inner {
      flex-direction: row;
    }
  }

  .copyright {
    font-size: var(--fs-caption);
    color: rgba(255, 255, 255, 0.5);
  }

  .legal-links {
    display: flex;
    gap: var(--space-4);
  }
  .legal-links a {
    font-size: var(--fs-caption);
    color: rgba(255, 255, 255, 0.5);
    display: inline-block;
    padding: 8px 0;
  }
  .legal-links a:hover {
    color: var(--color-white);
  }
</style>
