---
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
---

<section id="problem-section" class="section reveal">
  <div class="container">
    <SectionHeading 
      eyebrow="The Pain Points"
      title="Sound Familiar?"
      subtitle="Running a business is hard enough without the stress of manual bookkeeping."
    />

    <div class="grid grid-3 problem-grid">
      <!-- Pain 1 -->
      <Card 
        title="Drowning in Receipts & Spreadsheets" 
        description="Spending late nights reconciling transactions, chasing missing invoices, and manual data entry. Every hour on your books is an hour lost on growing your revenue."
        icon="true"
        class="problem-card"
      >
        <svg slot="icon-slot" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>
      </Card>

      <!-- Pain 2 -->
      <Card 
        title="Dreading Tax Season Every Year" 
        description="The annual scramble to organize receipts, figure out tax write-offs, and compile spreadsheets. Fearing late-filing IRS penalties or paying more than you actually owe."
        icon="true"
        class="problem-card"
      >
        <svg slot="icon-slot" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      </Card>

      <!-- Pain 3 -->
      <Card 
        title="Flying Blind on Cash Flow" 
        description="Making business decisions without knowing your exact margins or profits. Without real-time visibility, you might overcommit, miss payroll, or lose growth opportunities."
        icon="true"
        class="problem-card"
      >
        <svg slot="icon-slot" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
      </Card>
    </div>

    <div class="problem-footer text-center reveal reveal-delay-2">
      <p class="transition-text">It doesn't have to be this way.</p>
    </div>
  </div>
</section>

<style>
  .problem-grid {
    margin-top: var(--space-8);
  }

  .problem-card {
    border-color: rgba(239, 68, 68, 0.1);
  }
  .problem-card:hover {
    border-color: var(--color-semantic-error);
  }
  
  .problem-card :global(.card-icon) {
    color: var(--color-semantic-error);
    background-color: rgba(239, 68, 68, 0.05);
    padding: 10px;
    border-radius: var(--radius-md);
  }

  .problem-footer {
    margin-top: var(--space-8);
  }

  .transition-text {
    font-size: var(--fs-body-lg);
    font-weight: 600;
    color: var(--color-primary);
    font-style: italic;
  }
</style>
