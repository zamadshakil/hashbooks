---
import SectionHeading from '../ui/SectionHeading.astro';
import TestimonialCard from '../ui/TestimonialCard.astro';
import testimonialsData from '../../data/testimonials.json';
---

<section id="testimonials-section" class="section section-alt">
  <div class="container">
    <SectionHeading 
      eyebrow="Success Stories"
      title="Trusted by Growing Businesses"
      subtitle="Hear how we help entrepreneurs focus on scale by managing their numbers cleanly."
    />
  </div>

  <div class="testimonials-marquee-container">
    <div class="testimonials-marquee-track">
      <!-- Original Set -->
      {testimonialsData.map((item) => (
        <div class="marquee-item">
          <TestimonialCard 
            quote={item.quote}
            name={item.name}
            role={item.role}
            company={item.company}
            rating={item.rating}
          />
        </div>
      ))}
      <!-- Duplicated Set for Seamless Loop -->
      {testimonialsData.map((item) => (
        <div class="marquee-item" aria-hidden="true">
          <TestimonialCard 
            quote={item.quote}
            name={item.name}
            role={item.role}
            company={item.company}
            rating={item.rating}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-marquee-container {
    overflow: hidden;
    position: relative;
    width: 100%;
    margin-top: var(--space-8);
    padding: var(--space-4) 0;
  }

  /* Soft fade gradient masks on viewport edges */
  .testimonials-marquee-container::before,
  .testimonials-marquee-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 5;
    pointer-events: none;
  }

  .testimonials-marquee-container::before {
    left: 0;
    background: linear-gradient(to right, var(--color-bg-light) 0%, rgba(248, 250, 252, 0) 100%);
  }

  .testimonials-marquee-container::after {
    right: 0;
    background: linear-gradient(to left, var(--color-bg-light) 0%, rgba(248, 250, 252, 0) 100%);
  }

  .testimonials-marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 35s linear infinite;
  }

  .testimonials-marquee-track:hover {
    animation-play-state: paused;
  }

  .marquee-item {
    width: 380px;
    padding-right: var(--space-6);
    flex-shrink: 0;
    box-sizing: border-box;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .marquee-item {
      width: 310px;
      padding-right: var(--space-4);
    }
    .testimonials-marquee-container::before,
    .testimonials-marquee-container::after {
      width: 60px;
    }
  }
</style>
