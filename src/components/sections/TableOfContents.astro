---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

if (filteredHeadings.length === 0) return null;
---

<nav class="toc-container" aria-label="Table of Contents">
  <div class="toc-header">Table of Contents</div>
  <ul class="toc-list">
    {filteredHeadings.map(heading => (
      <li class={`toc-item depth-${heading.depth}`}>
        <a href={`#${heading.slug}`} class="toc-link" data-toc-slug={heading.slug}>
          {heading.text}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  // Active heading tracking on scroll
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -60% 0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        if (!id) return;
        
        // Remove active class from all links
        document.querySelectorAll('.toc-link').forEach(link => {
          link.classList.remove('active');
        });
        
        // Add active class to current link
        const activeLink = document.querySelector(`.toc-link[data-toc-slug="${id}"]`);
        if (activeLink) {
          activeLink.classList.add('active');
        }
      }
    });
  }, observerOptions);

  // Track all H2 and H3 headings in the article content
  const headings = document.querySelectorAll('.markdown-content h2, .markdown-content h3');
  headings.forEach(heading => observer.observe(heading));
</script>

<style>
  .toc-container {
    padding-left: var(--space-2);
  }

  .toc-header {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: var(--space-4);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid rgba(7, 32, 73, 0.06);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .toc-item {
    position: relative;
  }

  .toc-link {
    display: block;
    padding: 6px 0 6px 16px;
    margin-left: -2px; /* aligns border highlight over the list border */
    font-size: 14px;
    line-height: 1.4;
    color: #64748b;
    font-weight: 500;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .toc-item.depth-3 .toc-link {
    padding-left: 28px;
    font-size: 13px;
    color: #94a3b8;
  }

  .toc-link:hover {
    color: var(--color-primary);
  }

  .toc-link.active {
    color: var(--color-secondary) !important; /* brand green */
    font-weight: 700;
    border-left-color: var(--color-secondary) !important;
  }

  .toc-item.depth-3 .toc-link.active {
    border-left-color: var(--color-secondary) !important;
  }
</style>
