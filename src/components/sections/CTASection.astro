---
import Button from '../ui/Button.astro';
---

<section id="final-cta" class="section section-dark text-center">
  <div class="container final-cta-container">
    <h2 class="cta-title reveal">Ready for Financial Clarity?</h2>
    <p class="cta-subtitle reveal reveal-delay-1">
      Book a free 15-minute consultation. We'll analyze your current bookkeeping setup and provide a custom pricing quote.
    </p>
    <div class="cta-actions reveal reveal-delay-2">
      <Button text="Book Your Free Call" href="/get-a-quote/" variant="primary" size="lg" />
    </div>
    <p class="cta-trust reveal reveal-delay-3">
      <svg class="lock-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      Your data is always secure with us. No obligations.
    </p>
  </div>
</section>

<style>
  #final-cta {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary-light) 100%);
    padding: var(--space-16) 0;
  }

  @media (min-width: 768px) {
    #final-cta {
      padding: var(--space-24) 0;
    }
  }

  .final-cta-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-title {
    font-size: var(--fs-h1);
    font-weight: 700;
  }

  .cta-subtitle {
    font-size: var(--fs-body-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin-bottom: var(--space-4);
  }

  .cta-actions {
    display: flex;
    justify-content: center;
  }

  .cta-trust {
    font-size: var(--fs-caption);
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-2);
  }

  .lock-icon {
    color: var(--color-secondary-light);
  }
</style>
