---
interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      date: Date;
      author: string;
      category: string;
      image: string;
      readTime: string;
    }
  };
}

const { post } = Astro.props;
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="premium-blog-card">
  <a href={`/blog/${post.id}/`} class="card-image-link">
    <div class="card-image-wrapper">
      <img 
        src={post.data.image} 
        alt={post.data.title} 
        class="card-img" 
        width="380"
        height="240"
        loading="lazy"
        decoding="async"
      />
      <div class="card-image-overlay"></div>
      <span class="card-category-badge">{post.data.category}</span>
    </div>
  </a>
  <div class="card-content">
    <div class="card-meta">
      <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
      <span class="meta-dot"></span>
      <span class="read-time-tag">
        <svg class="meta-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        {post.data.readTime}
      </span>
    </div>
    
    <h3 class="card-title">
      <a href={`/blog/${post.id}/`}>{post.data.title}</a>
    </h3>
    
    <p class="card-excerpt">{post.data.description}</p>
    
    <a href={`/blog/${post.id}/`} class="card-arrow-link" aria-label={`Read article: ${post.data.title}`}>
      <span class="link-text">Read Article</span>
      <span class="arrow-circle">
        <svg class="arrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </span>
    </a>
  </div>
</article>

<style>
  .premium-blog-card {
    background-color: var(--color-white);
    border: 1px solid rgba(7, 32, 73, 0.07);
    border-radius: 20px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px -2px rgba(7, 32, 73, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .premium-blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px -12px rgba(7, 32, 73, 0.08);
    border-color: rgba(7, 32, 73, 0.15);
  }

  /* Add subtle top color bar on hover */
  .premium-blog-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-secondary) 100%);
    z-index: 20;
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .premium-blog-card:hover::before {
    opacity: 1;
  }

  .card-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--color-bg-light);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-blog-card:hover .card-img {
    transform: scale(1.03);
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(7, 32, 73, 0) 60%, rgba(7, 32, 73, 0.1) 100%);
    z-index: 2;
  }

  .card-category-badge {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 10;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.75px;
    box-shadow: 0 4px 12px rgba(7, 32, 73, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .premium-blog-card:hover .card-category-badge {
    background-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: var(--space-6) var(--space-6) var(--space-7);
  }

  .card-meta {
    display: flex;
    align-items: center;
    font-size: 12px;
    color: #64748b;
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .meta-dot {
    width: 4px;
    height: 4px;
    background-color: #cbd5e1;
    border-radius: var(--radius-full);
    margin: 0 var(--space-3);
  }

  .read-time-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .meta-icon {
    opacity: 0.7;
  }

  .card-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: var(--space-3);
    color: var(--color-text-heading);
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0% 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition: background-size 0.3s ease, color 0.3s ease;
  }

  .premium-blog-card:hover .card-title a {
    color: var(--color-accent);
    background-size: 100% 2px;
  }

  .card-excerpt {
    font-size: var(--fs-body-sm);
    color: #475569;
    line-height: 1.6;
    margin-bottom: var(--space-6);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .card-arrow-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-primary);
    font-size: var(--fs-body-sm);
    font-weight: 700;
    text-decoration: none;
    margin-top: auto;
    width: fit-content;
    transition: color var(--transition-fast);
  }

  .link-text {
    position: relative;
  }

  .link-text::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 1.5px;
    bottom: -2px;
    left: 0;
    background-color: var(--color-accent);
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .premium-blog-card:hover .card-arrow-link {
    color: var(--color-accent);
  }

  .premium-blog-card:hover .link-text::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .arrow-circle {
    width: 28px;
    height: 28px;
    background-color: var(--color-bg-light);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .arrow-icon {
    transition: transform 0.3s ease;
  }

  .premium-blog-card:hover .arrow-circle {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-white);
    transform: translateX(4px);
  }

  .premium-blog-card:hover .arrow-icon {
    transform: translateX(1px);
  }
</style>
