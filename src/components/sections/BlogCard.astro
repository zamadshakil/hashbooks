---
interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      date: Date;
      author: string;
      category: string;
      image: string;
      readTime: string;
    }
  };
}

const { post } = Astro.props;
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Map categories to soft color classes
const categoryClassMap: Record<string, string> = {
  "Bookkeeping": "cat-bookkeeping",
  "Tax & Compliance": "cat-tax",
  "Accounting Software": "cat-software",
  "Business Strategy": "cat-strategy"
};
const categoryClass = categoryClassMap[post.data.category] || "cat-default";
---

<article class="card blog-card">
  <a href={`/blog/${post.id}/`} class="blog-card-link-wrapper" aria-label={`Read article: ${post.data.title}`}>
    <div class="card-image-wrapper">
      <img 
        src={post.data.image} 
        alt={post.data.title} 
        class="card-img" 
        width="380"
        height="240"
        loading="lazy"
        decoding="async"
      />
      <div class="card-image-overlay"></div>
      <span class={`card-category-badge ${categoryClass}`}>{post.data.category}</span>
    </div>
    <div class="card-content">
      <div class="card-meta">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <span class="meta-dot"></span>
        <span class="read-time-tag">
          <svg class="meta-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {post.data.readTime}
        </span>
      </div>
      
      <h3 class="card-title">{post.data.title}</h3>
      
      <p class="card-excerpt">{post.data.description}</p>
      
      <div class="card-action-link">
        <span>Read Article</span>
        <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>
    </div>
  </a>
</article>
