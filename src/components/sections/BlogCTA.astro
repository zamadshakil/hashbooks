---
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
}

const { 
  title = "Ready to Delegate Your Bookkeeping?", 
  description = "Get a custom, flat-rate bookkeeping proposal customized for your business in 24 hours.", 
  buttonText = "Get My Free Proposal" 
} = Astro.props;
---

<div class="blog-cta-banner">
  <div class="blog-cta-content">
    <h4 class="blog-cta-title">{title}</h4>
    <p class="blog-cta-desc">{description}</p>
  </div>
  <div class="blog-cta-actions">
    <a href="/get-a-quote/" class="blog-cta-btn">{buttonText}</a>
  </div>
</div>

<style>
  .blog-cta-banner {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0b3c7a 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    color: var(--color-white);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-items: center;
    text-align: center;
    margin: var(--space-8) 0;
    box-shadow: 0 10px 30px -10px rgba(7, 32, 73, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 768px) {
    .blog-cta-banner {
      flex-direction: row;
      text-align: left;
      justify-content: space-between;
      padding: var(--space-8);
      gap: var(--space-8);
    }
  }

  .blog-cta-content {
    flex: 1;
  }

  .blog-cta-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .blog-cta-desc {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    line-height: 1.6;
  }

  .blog-cta-actions {
    flex-shrink: 0;
  }

  .blog-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--fs-body-sm);
    padding: 12px 24px;
    border-radius: var(--radius-md);
    background-color: var(--color-secondary);
    color: var(--color-white);
    text-decoration: none;
    transition: all var(--transition-fast);
    box-shadow: 0 4px 14px rgba(15, 112, 42, 0.35);
    border: 1.5px solid var(--color-secondary);
  }

  .blog-cta-btn:hover {
    background-color: var(--color-secondary-light);
    border-color: var(--color-secondary-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15, 112, 42, 0.45);
    color: var(--color-white);
  }
</style>
