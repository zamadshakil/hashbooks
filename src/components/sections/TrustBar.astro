---

<section id="trust-bar" class="trust-bar-section">
  <div class="container trust-container">
    <!-- Certifications Row -->
    <div class="certs-row">
      <div class="cert-item">
        <svg class="cert-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Certified QuickBooks ProAdvisors
      </div>
      <div class="cert-item">
        <svg class="cert-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Xero Advisor Certified
      </div>
      <div class="cert-item">
        <svg class="cert-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        AIPB Member Firm
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar-section {
    padding: var(--space-2) 0 var(--space-8) 0;
    background-color: transparent;
  }

  .trust-container {
    display: flex;
    justify-content: center;
  }

  /* Certs row styling */
  .certs-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .cert-item {
    font-size: var(--fs-caption);
    font-weight: 600;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: var(--color-bg-light);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .cert-check {
    color: var(--color-secondary);
  }
</style>
