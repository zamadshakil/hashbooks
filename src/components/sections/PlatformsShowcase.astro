---
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
---

<section id="platforms-showcase" class="section">
  <div class="container">
    <SectionHeading 
      eyebrow="Integrations"
      title="We Speak Your Software"
      subtitle="We work directly on all major cloud accounting platforms and payment processors."
    />

    <div class="grid grid-4 platforms-grid">
      <!-- QuickBooks -->
      <Card href="/platforms/quickbooks-online/" title="QuickBooks Online" description="Fully certified ProAdvisors handling setup, cleanups, and daily books." class="platform-card qbo-hover reveal reveal-delay-1" icon="true">
        <img slot="icon-slot" src="/images/platforms/quickbooks.svg" alt="QuickBooks" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- Xero -->
      <Card href="/platforms/xero/" title="Xero" description="Certified advisors structuring bank feeds and matching multi-currency feeds." class="platform-card xero-hover reveal reveal-delay-2" icon="true">
        <img slot="icon-slot" src="/images/platforms/xero.svg" alt="Xero" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- FreshBooks -->
      <Card href="/platforms/freshbooks/" title="FreshBooks" description="Reconciling billing, invoice trackers, and payments for agency clients." class="platform-card freshbooks-hover reveal reveal-delay-3" icon="true">
        <img slot="icon-slot" src="/images/platforms/freshbooks.svg" alt="FreshBooks" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- Zoho Books -->
      <Card href="/platforms/zoho-books/" title="Zoho Books" description="Integrating your bookkeeping inside your broader Zoho business suite." class="platform-card zoho-hover reveal reveal-delay-4" icon="true">
        <img slot="icon-slot" src="/images/platforms/zoho.svg" alt="Zoho Books" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- Wave -->
      <Card href="/platforms/wave-accounting/" title="Wave Accounting" description="Affordable, clean books management for freelancers and contractors." class="platform-card wave-hover reveal reveal-delay-1" icon="true">
        <img slot="icon-slot" src="/images/platforms/wave.svg" alt="Wave" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- Sage -->
      <Card href="/platforms/sage-business-cloud/" title="Sage Business Cloud" description="Structuring accounts for inventory-focused retail and wholesale trades." class="platform-card sage-hover reveal reveal-delay-2" icon="true">
        <img slot="icon-slot" src="/images/platforms/sage.svg" alt="Sage" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- Odoo -->
      <Card href="/platforms/odoo/" title="Odoo" description="Managing ledgers integrated with Odoo manufacturing, sales, and inventories." class="platform-card odoo-hover reveal reveal-delay-3" icon="true">
        <img slot="icon-slot" src="/images/platforms/odoo.svg" alt="Odoo" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
 
      <!-- NetSuite -->
      <Card href="/platforms/oracle-netsuite/" title="Oracle NetSuite" description="Strategic ERP management for scaling companies requiring multi-entity ledgers." class="platform-card netsuite-hover reveal reveal-delay-4" icon="true">
        <img slot="icon-slot" src="/images/platforms/netsuite.svg" alt="NetSuite" class="showcase-logo" loading="lazy" width="40" height="40" />
        <div class="card-footer">
          <span class="learn-more">
            Learn More
            <svg class="arrow-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </Card>
    </div>

    <p class="showcase-subtext text-center text-muted reveal reveal-delay-2">
      * All logos and trademarks are the property of their respective owners. We are certified partners on these platforms.
    </p>
  </div>
</section>

<style>
  .platforms-grid {
    margin-top: var(--space-8);
  }

  @media (max-width: 768px) {
    .platforms-grid {
      grid-template-columns: 1fr;
    }
  }

  .platform-card {
    border-color: var(--color-border);
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-footer {
    margin-top: auto;
    padding-top: var(--space-4);
    display: flex;
  }

  .learn-more {
    font-size: var(--fs-body-sm);
    font-weight: 700;
    color: var(--color-secondary);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }

  .arrow-right {
    transition: transform 0.2s ease;
  }

  :global(.platform-card):hover .learn-more {
    color: var(--color-primary-light);
  }

  :global(.platform-card):hover .arrow-right {
    transform: translateX(4px);
  }

  .showcase-logo {
    height: 40px;
    max-width: 140px;
    width: auto;
    object-fit: contain;
    margin-bottom: var(--space-2);
    filter: grayscale(100%);
    opacity: 0.6;
    transition: all var(--transition-normal);
  }

  :global(.platform-card):hover .showcase-logo {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.05);
  }

  /* Brand hovers */
  :global(.platform-card):hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }
  :global(.qbo-hover):hover { border-color: #2CA01C; }
  :global(.xero-hover):hover { border-color: #13B5EA; }
  :global(.freshbooks-hover):hover { border-color: #0075D2; }
  :global(.zoho-hover):hover { border-color: #E22B2B; }
  :global(.wave-hover):hover { border-color: #00C4CA; }
  :global(.sage-hover):hover { border-color: #008000; }
  :global(.odoo-hover):hover { border-color: #A24689; }
  :global(.netsuite-hover):hover { border-color: #4A90E2; }

  .showcase-subtext {
    margin-top: var(--space-8);
    font-size: var(--fs-caption);
  }
</style>
