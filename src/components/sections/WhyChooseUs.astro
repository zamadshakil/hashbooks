---
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
---

<section id="why-choose-us" class="section section-alt">
  <div class="container">
    <SectionHeading 
      eyebrow="Why Hashbooks"
      title="Why Businesses Choose Us"
      subtitle="We bring accuracy, security, and strategic clarity to your company's back-office finance operations."
    />

    <div class="grid grid-3 differentiators-grid">
      <!-- 1 -->
      <Card 
        title="Certified Experts" 
        description="Every bookkeeper at HashBooks holds active QuickBooks ProAdvisor or Xero Advisor certifications."
        icon="true"
        class="diff-card reveal reveal-delay-1"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      </Card>

      <!-- 2 -->
      <Card 
        title="Industry Specialists" 
        description="We tailor categorization rules for e-commerce, real estate, healthcare, and professional services."
        icon="true"
        class="diff-card reveal reveal-delay-2"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg>
      </Card>

      <!-- 3 -->
      <Card 
        title="Dedicated Support" 
        description="A single designated bookkeeper assigned to your account who understands your transactions intimately."
        icon="true"
        class="diff-card reveal reveal-delay-3"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      </Card>

      <!-- 4 -->
      <Card 
        title="Cloud-Native Flow" 
        description="We hook directly into your cloud platforms — bank feeds, payment processors, and POS feeds."
        icon="true"
        class="diff-card reveal reveal-delay-1"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-.08A7 7 0 0 0 4.75 9.07A8 8 0 0 0 8 24h10a6 6 0 0 0 0-12z"></path></svg>
      </Card>

      <!-- 5 -->
      <Card 
        title="Transparent Pricing" 
        description="Custom flat monthly pricing. No hourly billing surprises, no hidden transaction surcharges."
        icon="true"
        class="diff-card reveal reveal-delay-2"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12" y2="18.01"></line><line x1="12" y1="13" x2="12" y2="13.01"></line><line x1="12" y1="8" x2="12" y2="8.01"></line><path d="M16 8h2v2M18 14h-2v2M8 16H6v-2M6 10h2V8"></path></svg>
      </Card>

      <!-- 6 -->
      <Card 
        title="SOC 2 Security" 
        description="Bank-level 256-bit encryption and strict compliance protocols keeping your financial data secure."
        icon="true"
        class="diff-card reveal reveal-delay-3"
      >
        <svg slot="icon-slot" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </Card>
    </div>
  </div>
</section>

<style>
  .differentiators-grid {
    margin-top: var(--space-8);
  }

  .diff-card {
    border-color: var(--color-border);
  }

  .diff-card :global(.card-icon) {
    color: var(--color-secondary);
  }
</style>
