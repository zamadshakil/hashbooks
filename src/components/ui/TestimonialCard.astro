---
interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
  rating?: number;
}

const { quote, name, role, company, rating = 5 } = Astro.props;
---

<div class="card testimonial-card reveal">
  <div class="rating-stars">
    {Array.from({ length: rating }).map((_, i) => (
      <svg class="star-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
    ))}
  </div>
  
  <blockquote class="testimonial-quote">
    "{quote}"
  </blockquote>
  
  <div class="testimonial-author">
    <div class="author-details">
      <cite class="author-name">{name}</cite>
      <span class="author-meta">{role}, {company}</span>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    padding: var(--space-6);
    background-color: var(--color-white);
    border: 1px solid rgba(7, 32, 73, 0.06);
    border-radius: var(--radius-xl);
    box-shadow: 0 10px 30px -10px rgba(7, 32, 73, 0.04);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .testimonial-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px -15px rgba(26, 122, 61, 0.1);
    border-color: rgba(26, 122, 61, 0.15);
  }

  .quote-icon {
    position: absolute;
    top: var(--space-2);
    right: var(--space-6);
    font-size: 90px;
    font-family: Georgia, serif;
    color: rgba(7, 32, 73, 0.04);
    line-height: 1;
    pointer-events: none;
  }

  .rating-stars {
    color: #F59E0B; /* Vibrant Golden Stars */
    margin-bottom: var(--space-4);
    display: flex;
    gap: 3px;
    position: relative;
    z-index: 2;
  }

  .testimonial-quote {
    font-size: var(--fs-body-sm);
    color: var(--color-text-body);
    font-style: italic;
    line-height: 1.7;
    margin-bottom: var(--space-6);
    position: relative;
    z-index: 2;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    position: relative;
    z-index: 2;
  }

  .avatar-initials {
    width: 42px;
    height: 42px;
    border-radius: var(--radius-full);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  .author-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    display: block;
    font-weight: 700;
    font-style: normal;
    color: var(--color-text-heading);
    font-size: var(--fs-body-sm);
  }

  .author-meta {
    font-size: var(--fs-caption);
    color: var(--color-text-muted);
  }
</style>
