---
interface Props {
  text: string;
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  text,
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  id,
  ...rest
} = Astro.props;

const buttonClass = `btn btn-${variant} btn-${size} ${className}`;
---

{href ? (
  <a href={href} class={buttonClass} id={id} {...rest}>
    {text}
  </a>
) : (
  <button type={type} class={buttonClass} id={id} {...rest}>
    {text}
  </button>
)}
