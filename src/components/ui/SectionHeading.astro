---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean;
  as?: 'h1' | 'h2';
}

const {
  eyebrow,
  title,
  subtitle,
  align = 'center',
  light = false,
  as = 'h2',
} = Astro.props;

const alignmentClass = align === 'left' ? 'align-left' : 'align-center';
const themeClass = light ? 'theme-light' : '';
const Heading = as;
---

<div class={`section-heading ${alignmentClass} ${themeClass} reveal`}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <Heading class="title">{title}</Heading>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--space-8);
  }

  .align-center {
    text-align: center;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .align-left {
    text-align: left;
    max-width: 700px;
  }

  .eyebrow {
    display: block;
    font-size: var(--fs-caption);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-secondary);
    margin-bottom: var(--space-2);
  }

  .title {
    margin-bottom: var(--space-3);
  }

  h1.title {
    font-size: var(--fs-h1);
  }

  h2.title {
    font-size: var(--fs-h2);
  }

  .subtitle {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
  }

  /* Light theme on dark sections */
  .theme-light .title {
    color: var(--color-white);
  }
  .theme-light .subtitle {
    color: rgba(255, 255, 255, 0.7);
  }
  .theme-light .eyebrow {
    color: var(--color-secondary-light);
  }
</style>
