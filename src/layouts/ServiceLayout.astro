---
import PageLayout from './PageLayout.astro';
import Button from '../components/ui/Button.astro';
import Accordion from '../components/ui/Accordion.astro';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';
import { Image } from 'astro:assets';
import servicesData from '../data/services.json';

interface Props {
  slug: string;
  title: string;
  description: string;
  heroDescription: string;
  icon: string;
  features: string[];
  targetClients: string[];
  process: { step: string; title: string; description: string }[];
  faqs: { question: string; answer: string }[];
  relatedServices: string[];
}

const {
  slug,
  title,
  description,
  heroDescription,
  features,
  targetClients,
  process,
  faqs,
  relatedServices,
} = Astro.props;
const canonicalUrl = `/services/${slug}/`;
const breadcrumbData = {
  items: [
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services/' },
    { name: title, url: canonicalUrl }
  ]
};

// Map related service slugs to their full data objects
const relatedServiceObjects = relatedServices
  .map(rSlug => servicesData.find(s => s.slug === rSlug))
  .filter(Boolean);
---

<PageLayout title={`${title} Services | Hashbooks`} description={description} canonicalUrl={canonicalUrl}>
  <SchemaMarkup type="service" data={{ title, description, url: canonicalUrl }} slot="head" />
  <SchemaMarkup type="breadcrumb" data={breadcrumbData} slot="head" />
  {faqs && faqs.length > 0 && <SchemaMarkup type="faq" data={{ items: faqs }} slot="head" />}
  <!-- Breadcrumb -->
  <div class="breadcrumbs-container">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li>
            <a href="/">
              <svg class="home-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 5px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              Home
            </a>
          </li>
          <li class="breadcrumb-separator" aria-hidden="true">/</li>
          <li><a href="/services/">Services</a></li>
          <li class="breadcrumb-separator" aria-hidden="true">/</li>
          <li class="active" aria-current="page">{title}</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Service Hero -->
  <section class="section service-hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <h1 class="service-title">{title}</h1>
        <p class="service-lead">{heroDescription}</p>
        <div class="hero-actions">
          <Button text="Get Started Today" href="/get-a-quote/" variant="primary" size="lg" />
          <Button text="Speak to an Expert" href="https://calendly.com/hashbooksofficial" variant="secondary" size="lg" target="_blank" rel="noopener noreferrer" />
        </div>
      </div>
      <div class="hero-illustration">
        <div class="service-image-box">
          <Image 
            src={`/images/services/${slug}.png`} 
            alt={title} 
            class="service-hero-img" 
            width={440} 
            height={330} 
            format="webp" 
            quality={80} 
            loading="eager" 
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Split Features and Target Audiences -->
  <section class="section section-alt">
    <div class="container split-grid">
      <!-- Left: What's Included -->
      <div class="included-col">
        <h2 class="section-subheading">What's Included</h2>
        <ul class="check-list">
          {features.map((feature) => (
            <li class="check-list-item">
              <svg class="check-list-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: Target Clients -->
      <div class="audience-col">
        <h2 class="section-subheading">Who This Is For</h2>
        <div class="audience-list">
          {targetClients.map((client) => (
            <div class="audience-card">
              <svg class="audience-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              <span class="audience-text">{client}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process / Workflow -->
  <section class="section">
    <div class="container text-center">
      <h2 class="section-subheading text-center">How It Works</h2>
      <div class="process-grid">
        {process.map((step) => (
          <div class="process-card">
            <div class="process-step-num">{step.step}</div>
            <h3 class="process-card-title">{step.title}</h3>
            <p class="process-card-desc">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section section-alt">
    <div class="container max-width-800">
      <h2 class="section-subheading text-center">Frequently Asked Questions</h2>
      <div class="faq-accordion-group">
        {faqs.map((faq) => (
          <Accordion question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServiceObjects.length > 0 && (
    <section class="section related-services-section">
      <div class="container">
        <h2 class="section-subheading text-center">Related Services</h2>
        <div class="related-services-grid">
          {relatedServiceObjects.map((rService: any) => (
            <a href={`/services/${rService.slug}/`} class="related-service-card card">
              <div>
                <h3 class="related-service-title">
                  {rService.title}
                  <svg class="arrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </h3>
                <p class="related-service-desc">{rService.heroDescription.substring(0, 115)}...</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="section final-service-cta text-center">
    <div class="container">
      <h2 class="cta-heading">Ready to Streamline Your Finance Operations?</h2>
      <p class="cta-sub">Let's build a custom plan that fits your business needs perfectly.</p>
      <Button text="Request Your Free Proposal" href="/get-a-quote/" size="lg" />
    </div>
  </section>
</PageLayout>

<style>
  .breadcrumbs-container {
    background-color: transparent;
    border-bottom: none;
    padding: var(--space-8) 0 0 0;
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .breadcrumb-list a {
    color: var(--color-text-muted);
    transition: color var(--transition-normal);
    display: flex;
    align-items: center;
  }
  .breadcrumb-list a:hover {
    color: var(--color-secondary);
  }
  .breadcrumb-list li {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
  }
  .breadcrumb-separator {
    color: var(--color-border);
    margin: 0 var(--space-1);
    font-weight: 400;
  }
  .breadcrumb-list .active {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Service Hero */
  .service-hero {
    padding: var(--space-8) 0 var(--space-12);
    background: radial-gradient(circle at 10% 20%, rgba(26, 122, 61, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(7, 32, 73, 0.02) 0%, transparent 40%);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .service-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    letter-spacing: -0.5px;
  }
  .service-lead {
    font-size: var(--fs-body-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
    }
    .hero-actions :global(.btn) {
      width: 100%;
    }
  }

  .service-image-box {
    width: 100%;
    max-width: 440px;
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 40px -15px rgba(7, 32, 73, 0.15);
    border: 1px solid var(--color-border);
    overflow: hidden;
    background-color: var(--color-white);
    transition: transform var(--transition-normal);
  }
  .service-image-box:hover {
    transform: translateY(-4px);
  }
  .service-hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Split grid features/audiences */
  .split-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 768px) {
    .split-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .section-subheading {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-6);
    color: var(--color-text-heading);
    font-weight: 700;
  }

  /* Features List */
  .check-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .check-list-item {
    display: flex;
    gap: var(--space-4);
    font-size: var(--fs-body);
    color: var(--color-text-body);
    line-height: 1.5;
    align-items: center;
    padding: var(--space-4);
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-sm);
  }
  .check-list-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px -4px rgba(7, 32, 73, 0.06);
    border-color: rgba(26, 122, 61, 0.25);
  }
  .check-list-icon {
    color: var(--color-secondary);
    background-color: rgba(26, 122, 61, 0.08);
    padding: var(--space-1);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .audience-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .audience-card {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4);
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .audience-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px -4px rgba(7, 32, 73, 0.06);
    border-color: rgba(26, 122, 61, 0.25);
  }
  .audience-icon {
    color: var(--color-secondary);
    background-color: rgba(26, 122, 61, 0.08);
    padding: var(--space-1);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }
  .audience-text {
    font-size: var(--fs-body);
    color: var(--color-text-body);
    line-height: 1.5;
  }

  /* Process Cards */
  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }
  @media (min-width: 640px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
  @media (min-width: 992px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .process-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    text-align: center;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-sm);
  }
  .process-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--color-secondary), var(--color-secondary-light));
    border-top-left-radius: var(--radius-lg);
    border-top-right-radius: var(--radius-lg);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .process-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 25px -5px rgba(26, 122, 61, 0.08), 0 10px 10px -5px rgba(26, 122, 61, 0.03);
    border-color: rgba(26, 122, 61, 0.25);
  }
  .process-card:hover::before {
    opacity: 1;
  }
  .process-step-num {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--color-secondary), #135d2e);
    color: var(--color-white);
    font-weight: 700;
    font-size: var(--fs-body-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
    box-shadow: 0 4px 10px rgba(26, 122, 61, 0.2);
    transition: all 0.3s ease;
  }
  .process-card:hover .process-step-num {
    transform: scale(1.1);
    box-shadow: 0 8px 16px rgba(26, 122, 61, 0.3);
  }
  .process-card-title {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: var(--space-3);
  }
  .process-card-desc {
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* FAQs accordion max-width */
  .max-width-800 {
    max-width: 800px;
    margin: 0 auto;
  }

  /* Final service CTA */
  .final-service-cta {
    background-color: var(--color-primary-dark);
    color: var(--color-white);
    padding: var(--space-16) 0;
  }
  .cta-heading {
    color: var(--color-white);
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
  }
  .cta-sub {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-6);
  }

  /* Related Services Section styles */
  .related-services-section {
    background-color: var(--color-bg-light);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-12) 0;
  }
  .related-services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }
  @media (min-width: 640px) {
    .related-services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 992px) {
    .related-services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .related-service-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all var(--transition-normal);
  }
  .related-service-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-secondary);
    box-shadow: var(--shadow-md);
  }
  .related-service-title {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .related-service-title .arrow-icon {
    color: var(--color-secondary);
    transition: transform var(--transition-fast);
  }
  .related-service-card:hover .arrow-icon {
    transform: translateX(4px);
  }
  .related-service-desc {
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
