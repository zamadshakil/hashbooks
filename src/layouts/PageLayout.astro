---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, canonicalUrl, ogImage, ogType, noindex } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType={ogType}
  noindex={noindex}
>
  <slot name="head" slot="head" />
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    flex: 1 0 auto;
    /* Spacing offset for the sticky/floating navbar transition */
    padding-top: 86px; 
  }
</style>
