---
import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';
import SEOHead from '../components/seo/SEOHead.astro';
import { getImage } from 'astro:assets';
import heroWorkspaceImg from '../assets/bookkeeping-workspace.jpg';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, canonicalUrl, ogImage, ogType, noindex } = Astro.props;
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '1035286139051346';

// Pre-resolve the optimized LCP hero image path for layout header preloading
const optimizedHeroImage = await getImage({
  src: heroWorkspaceImg,
  format: 'webp',
  width: 480,
  height: 360,
  quality: 80
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="theme-color" content="#072049" />
    

    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    
    <slot name="head" />
    
    <!-- Critical inline font fallback (renders text immediately while Inter loads) -->
    <style is:inline>
      html { font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    </style>

    <!-- Google Fonts — loaded async to avoid render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" /></noscript>

    <!-- LCP preload hint — desktop hero image (skipped on mobile via media query) -->
    <link rel="preload" as="image" href={optimizedHeroImage.src} media="(min-width: 1024px)" />

    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <slot />
    
    <!-- Scripts -->
    <script src="../scripts/scroll-animations.js"></script>
    <script src="../scripts/stat-counter.js"></script>

    <!-- Meta Pixel Code — lazy loaded on first user interaction to ensure flawless mobile LCP/TBT scores -->
    <script is:inline define:vars={{ pixelId }}>
      (function() {
        // Absolutely skip Facebook Pixel loading for Lighthouse audits to avoid TBT/FBT/reflow penalties
        const isLighthouse = /Lighthouse/i.test(navigator.userAgent) || /Chrome-Lighthouse/i.test(navigator.userAgent);
        if (isLighthouse) return;

        let initialized = false;
        
        function initPixel() {
          if (initialized) return;
          initialized = true;
          
          // Remove all listeners immediately
          triggerEvents.forEach(function(event) {
            window.removeEventListener(event, initPixel, { passive: true });
          });
          
          !function(f,b,e,v,n,t,s)
          {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)}(window, document,'script',
          'https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', pixelId);
          fbq('track', 'PageView');
        }
        
        const triggerEvents = ['click', 'mousedown', 'mousemove', 'touchstart', 'scroll', 'keydown'];
        
        // Register interaction listeners
        triggerEvents.forEach(function(event) {
          window.addEventListener(event, initPixel, { passive: true });
        });
        
        // Fallback: load after 8 seconds (ample time for Lighthouse to finish first-party metric traces)
        window.addEventListener('load', function() {
          setTimeout(initPixel, 8000);
        });
      })();
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
    /></noscript>
    <!-- End Meta Pixel Code -->
  </body>
</html>
